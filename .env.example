# ──────────────────────────────────────────────────────────────────────────────
# AirLines Backend – environment variable template
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection URL (required)
# Format: postgres://<user>:<password>@<host>:<port>/<database>?sslmode=disable
DATABASE_URL=postgres://postgres:password@localhost:5432/airlines?sslmode=disable

# Path to the SQL migration files, relative to the working directory (optional)
# Default: migrations
MIGRATIONS_PATH=migrations

# Port the HTTP server listens on (optional)
# Default: 8080
SERVER_PORT=8080
